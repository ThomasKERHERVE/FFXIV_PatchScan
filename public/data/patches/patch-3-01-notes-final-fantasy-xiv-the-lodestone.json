  "jobs_pve": [
    {
      "job": "Bard",
      "changes": [
        "the Wanderer's Minuet: Action category has been changed from spell to ability.",
        "the Wanderer's Minuet: Damage increase has been increased from 20% to 30%.",
        "the Wanderer's Minuet: Cast time has been reduced from 3 to 0 seconds.",
        "the Wanderer's Minuet: Recast time has been increased from 2.5 to 15 seconds.",
        "Empyreal Arrow: Potency has been reduced from 240 to 220.",
        "Sidewinder: Potency has been reduced from 150 to 100.",
        "Sidewinder: Potency when target is suffering from either Venomous Bite or Windbite has been reduced from 250 to 175.",
        "Sidewinder: Potency when target is suffering from both Venomous Bite and Windbite has been reduced from 350 to 250."
      ]
    },
    {
      "job": "Machinist",
      "changes": [
        "Gauss Barrel: Damage increase has been increased from 20% to 30%.",
        "Gauss Barrel: Cast time has been reduced from 3 to 0 seconds.",
        "Gauss Barrel: Recast time has been increased from 2.5 to 15 seconds.",
        "Gauss Round: Potency has been reduced from 200 to 180.",
        "Ricochet: Potency of the area attack has been reduced from 300 to 200."
      ]
    }
  ],
